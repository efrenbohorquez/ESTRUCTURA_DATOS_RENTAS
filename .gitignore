# ════════════════════════════════════════════
# ESTRUCTURA DATOS RENTAS — .gitignore
# ════════════════════════════════════════════

# Datos (pesados, no rastreables)
*.xlsx
*.xls
*.csv
data/

# Outputs regenerables
outputs/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Jupyter checkpoints
.ipynb_checkpoints/

# IDE
.vscode/
.idea/

# OS
Thumbs.db
.DS_Store

# Temporales
*.log
temp_*
error_*
